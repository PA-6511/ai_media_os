{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SoC Task Acceptance Result Contract",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "node_id",
    "task_type",
    "execution_mode",
    "decision",
    "reason",
    "input_metrics",
    "enforced_limits",
    "safeguards"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "soc_task_acceptance_result_v1"},
    "request_id": {"type": "string", "minLength": 1},
    "node_id": {"type": "string", "minLength": 1},
    "task_type": {"type": "string"},
    "execution_mode": {"type": "string", "const": "DRY_RUN_ONLY"},
    "decision": {"type": "string", "enum": ["PASS", "ABORT"]},
    "reason": {"type": "string", "minLength": 1},
    "reason_codes": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "input_metrics": {
      "type": "object",
      "required": ["input_lines", "input_chars"],
      "properties": {
        "input_lines": {"type": "integer", "minimum": 0},
        "input_chars": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "enforced_limits": {
      "type": "object",
      "required": ["max_input_lines", "max_input_chars"],
      "properties": {
        "max_input_lines": {"type": "integer", "minimum": 1},
        "max_input_chars": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "safeguards": {
      "type": "object",
      "required": [
        "design_only",
        "no_execution",
        "external_api_call",
        "wordpress_write",
        "shell_execution",
        "credential_operation"
      ],
      "properties": {
        "design_only": {"type": "boolean", "const": true},
        "no_execution": {"type": "boolean", "const": true},
        "external_api_call": {"type": "boolean", "const": false},
        "wordpress_write": {"type": "boolean", "const": false},
        "shell_execution": {"type": "boolean", "const": false},
        "credential_operation": {"type": "boolean", "const": false}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
